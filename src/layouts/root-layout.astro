---
import "@fontsource-variable/inter";
import ThemeInitializer from "components/head/theme-initializer.astro";
import Header from "components/header";
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <slot name="meta" />
    <ThemeInitializer />
  </head>
  <body
    class="bg-slate-50 font-sans text-slate-800 dark:bg-slate-950 dark:text-slate-200"
  >
    <Header />
    <main class="min-h-screen px-8 py-20">
      <slot />
    </main>
  </body>
</html>
