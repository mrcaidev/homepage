<button
  type="button"
  role="switch"
  aria-label="use dark mode"
  aria-checked="false"
  class="theme-toggle w-11 h-6 border border-slate-300 dark:border-slate-700 hover:border-sky-600 dark:hover:border-sky-400 rounded-full bg-slate-200 dark:bg-slate-800 transition-colors"
>
  <span
    class="grid place-items-center dark:translate-x-5.5 w-5 h-5 rounded-full bg-slate-50 dark:bg-slate-950 transition-transform"
  >
    <span class="dark:i-tabler-moon i-tabler-sun-high text-xs"></span>
  </span>
</button>

<script>
  const toggles = [
    ...document.querySelectorAll(".theme-toggle"),
  ] as HTMLButtonElement[];

  let isDark = document.documentElement.classList.contains("dark");

  function syncToggles() {
    const ariaLabel = isDark ? "Use light mode" : "Use dark mode";
    const ariaChecked = isDark ? "true" : "false";
    toggles.forEach((button) => {
      button.setAttribute("aria-label", ariaLabel);
      button.setAttribute("aria-checked", ariaChecked);
    });
  }

  function syncLocalStorage() {
    const theme = isDark ? "dark" : "light";
    localStorage.setItem("theme", theme);
  }

  syncToggles();

  toggles.forEach((button) => {
    button.addEventListener("click", () => {
      isDark = !isDark;
      document.documentElement.classList.toggle("dark");
      syncToggles();
      syncLocalStorage();
    });
  });
</script>
