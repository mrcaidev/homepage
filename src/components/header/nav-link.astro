---
export type Props = {
  href: string;
};

const { href } = Astro.props;

const isActive = Astro.url.pathname.startsWith(href);
---

<a
  href={href}
  class:list={[
    "md:px-4 py-4 font-500",
    isActive
      ? "text-sky-600 dark:text-sky-400"
      : "hover:text-sky-600 dark:hover:text-sky-400 transition-colors",
  ]}
>
  <slot />
</a>
