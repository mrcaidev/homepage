---
export type Props = {
  href: string;
  label: string;
};

const { href, label } = Astro.props;
---

<a
  href={href}
  target="_blank"
  class="text-3xl text-slate-600 dark:text-slate-400 hover:text-sky-600 dark:hover:text-sky-400 transition-colors"
>
  <slot />
  <span class="sr-only">{label}</span>
</a>
