---
export interface Props {
  title: string;
  description: string;
  publishedTime: string;
  modifiedTime: string;
  tags: string[];
}

const { title, description, publishedTime, modifiedTime, tags } = Astro.props;

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description,
  image: new URL("opengraph-image.png", Astro.site),
  datePublished: new Date(publishedTime).toISOString(),
  dateModified: new Date(modifiedTime).toISOString(),
  author: { "@type": "Person", name: "Yuwang Cai", url: Astro.site },
});
---

<meta property="og:type" content="article" />

<meta property="article:published_time" content={publishedTime} />
<meta property="article:modified_time" content={modifiedTime} />
<meta property="article:author" content={Astro.site} />
<meta property="article:section" content="technology" />
{tags.map((tag) => <meta property="article:tag" content={tag} />)}

<script type="application/ld+json" set:html={jsonLd} />
